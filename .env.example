DATABASE_URL="postgresql://vps_manager:vps_manager@localhost:5432/vps_manager?schema=public"
PORT=8080
PUBLIC_URL="http://localhost:8080"

# Token used by browser/API callers. Change this before exposing the app.
ADMIN_TOKEN="change-me-admin-token"

# Agent runtime config, used on each VPS.
CENTRAL_URL="ws://localhost:8080"
AGENT_TOKEN="paste-server-agent-token-here"
AGENT_NAME="vps-01"
HEARTBEAT_INTERVAL_MS=15000
